	}
	protected void do_btnNewButton_actionPerformed(ActionEvent e) 
	{
	        String codigo = txtCod.getText();
	        Estudiante est = arreglo.buscar(codigo);

	        if (est != null) 
	        {
	            est.setNombre(txtNom.getText());
	            est.setNota1(Double.parseDouble(txtN1.getText()));
	            est.setNota2(Double.parseDouble(txtN2.getText()));
	            JOptionPane.showMessageDialog(null, "Estudiante modificado");
	        } else 
	        {
	            JOptionPane.showMessageDialog(null, "No se encontró el estudiante");
	        }
	    
	}
	protected void do_btnNewButton_3_actionPerformed(ActionEvent e) 
